<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
<title>Bead & Stone Counter</title>
<style>
  :root {
    --bg: #0f1115;
    --panel: #181b22;
    --panel-2: #1f232c;
    --ink: #eef1f6;
    --muted: #8a92a3;
    --accent: #7cd4b0;
    --accent-2: #f4c06a;
    --danger: #e26d6d;
    --border: #2a2f3a;
  }
  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink);
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    overscroll-behavior: none;
  }
  header {
    padding: 14px 16px 10px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
  }
  header h1 { font-size: 17px; margin: 0; font-weight: 600; letter-spacing: .2px; }
  header .sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
  main { padding: 14px 14px 120px; max-width: 860px; margin: 0 auto; }

  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    margin-bottom: 14px;
  }
  label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; }
  input[type="text"], input[type="password"], select, textarea {
    width: 100%; padding: 10px 12px; border-radius: 10px;
    background: var(--panel-2); border: 1px solid var(--border);
    color: var(--ink); font-size: 14px; outline: none;
  }
  input:focus, select:focus { border-color: var(--accent); }
  .row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .row > * { flex: 1; min-width: 0; }
  .btn {
    appearance: none; border: 0; border-radius: 10px;
    padding: 12px 14px; font-size: 14px; font-weight: 600;
    background: var(--accent); color: #0b1a14; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  }
  .btn.secondary { background: var(--panel-2); color: var(--ink); border: 1px solid var(--border); }
  .btn.ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
  .btn:disabled { opacity: .55; cursor: not-allowed; }
  .btn-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .btn-row .btn { flex: 1; min-width: 120px; }

  .pill {
    display: inline-block; padding: 3px 8px; border-radius: 999px;
    font-size: 11px; background: var(--panel-2); border: 1px solid var(--border); color: var(--muted);
  }

  .viewer {
    position: relative; width: 100%; aspect-ratio: 4/3;
    background: #000; border-radius: 12px; overflow: hidden;
    border: 1px solid var(--border);
    touch-action: none;
  }
  .viewer .stage {
    position: absolute; inset: 0;
    transform-origin: 0 0;
    will-change: transform;
  }
  .viewer img, .viewer canvas {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    display: block;
    image-rendering: -webkit-optimize-contrast;
  }
  .viewer .hint {
    position: absolute; inset: auto 0 0 0; padding: 8px 10px;
    background: linear-gradient(to top, rgba(0,0,0,.6), rgba(0,0,0,0));
    font-size: 11px; color: #cfd4de; pointer-events: none;
  }

  .count-badge {
    position: absolute; top: 10px; left: 10px;
    background: rgba(15,17,21,.82); border: 1px solid var(--border);
    padding: 8px 12px; border-radius: 999px; font-weight: 700; font-size: 14px;
    backdrop-filter: blur(6px);
  }
  .zoom-controls {
    position: absolute; top: 10px; right: 10px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .zoom-controls button {
    width: 36px; height: 36px; border-radius: 10px;
    background: rgba(15,17,21,.82); border: 1px solid var(--border);
    color: var(--ink); font-size: 18px; cursor: pointer;
    backdrop-filter: blur(6px);
  }

  .status {
    font-size: 13px; color: var(--muted); min-height: 18px;
    display: flex; align-items: center; gap: 8px;
  }
  .status.err { color: var(--danger); }
  .spinner {
    width: 14px; height: 14px; border-radius: 50%;
    border: 2px solid var(--border); border-top-color: var(--accent);
    animation: spin .8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  details.advanced { margin-top: 8px; }
  details.advanced summary {
    cursor: pointer; font-size: 12px; color: var(--muted);
    list-style: none; padding: 6px 0;
  }
  details.advanced summary::-webkit-details-marker { display: none; }
  details.advanced summary::before { content: "▸ "; }
  details.advanced[open] summary::before { content: "▾ "; }

  .seg { display: flex; background: var(--panel-2); border: 1px solid var(--border); border-radius: 10px; padding: 3px; gap: 3px; }
  .seg button {
    flex: 1; padding: 8px 10px; border: 0; background: transparent;
    color: var(--muted); font-size: 12px; font-weight: 600; border-radius: 8px; cursor: pointer;
  }
  .seg button.on { background: var(--accent); color: #0b1a14; }

  .footer-note { text-align: center; color: var(--muted); font-size: 11px; margin-top: 16px; }
  .hidden { display: none !important; }

  @media (min-width: 720px) {
    .viewer { aspect-ratio: 16/10; }
  }
</style>
</head>
<body>

<header>
  <div>
    <h1>Bead &amp; Stone Counter</h1>
    <div class="sub">Tap to capture • AI counts each piece</div>
  </div>
  <span class="pill" id="modelPill">Gemini 2.0 Flash</span>
</header>

<main>

  <!-- API KEY -->
  <section class="card" id="keyCard">
    <label for="apiKey">Google AI Studio API Key</label>
    <div class="row">
      <input type="password" id="apiKey" placeholder="Paste your free API key…" autocomplete="off" />
      <button class="btn secondary" id="saveKey" style="flex:0 0 auto">Save</button>
    </div>
    <div class="status" id="keyStatus">Key is stored locally in your browser.</div>
  </section>

  <!-- MODE -->
  <section class="card">
    <label>What are you counting?</label>
    <div class="seg" id="modeSeg">
      <button data-mode="beadlinks" class="on">Bead Links</button>
      <button data-mode="stones">Stones</button>
      <button data-mode="generic">Custom</button>
    </div>
    <div id="customWrap" class="hidden" style="margin-top:10px">
      <label for="customObj">Describe the item</label>
      <input type="text" id="customObj" placeholder="e.g. small green emerald beads with gold wire" />
    </div>
    <details class="advanced">
      <summary>Advanced</summary>
      <div style="padding-top:8px">
        <label for="density">Expected density</label>
        <select id="density">
          <option value="sparse">Sparse — spread out</option>
          <option value="normal" selected>Normal</option>
          <option value="dense">Dense — tightly clustered</option>
        </select>
        <label for="maxDim" style="margin-top:10px">Image size sent (max edge, px)</label>
        <select id="maxDim">
          <option value="1024">1024 (faster)</option>
          <option value="1536" selected>1536 (balanced)</option>
          <option value="2048">2048 (best for tiny items)</option>
        </select>
      </div>
    </details>
  </section>

  <!-- IMAGE -->
  <section class="card">
    <div class="btn-row">
      <button class="btn" id="pickBtn">📷 Take / Choose Photo</button>
      <button class="btn secondary" id="countBtn" disabled>✨ Count</button>
    </div>
    <input type="file" id="fileInput" accept="image/*" capture="environment" class="hidden" />

    <div class="viewer hidden" id="viewer">
      <div class="stage" id="stage">
        <img id="preview" alt="preview" />
        <canvas id="overlay"></canvas>
      </div>
      <div class="count-badge hidden" id="countBadge">—</div>
      <div class="zoom-controls">
        <button id="zoomIn" title="Zoom in">+</button>
        <button id="zoomOut" title="Zoom out">−</button>
        <button id="zoomReset" title="Reset">⟲</button>
      </div>
      <div class="hint">Pinch or use +/− to zoom. Drag to pan.</div>
    </div>

    <div class="status" id="status" style="margin-top:10px"></div>
  </section>

  <div class="footer-note">
    Works offline after first load • API calls go directly to Google<br/>
    Your key and photos never touch any other server.
  </div>
</main>

<script>
/* ---------------- State ---------------- */
const $ = (id) => document.getElementById(id);
const state = {
  apiKey: localStorage.getItem("gemini_key") || "",
  mode: "beadlinks",
  imageDataUrl: null,
  imageBlob: null,
  detections: [],
  zoom: 1, panX: 0, panY: 0,
};

/* ---------------- API Key ---------------- */
$("apiKey").value = state.apiKey;
$("saveKey").addEventListener("click", () => {
  const v = $("apiKey").value.trim();
  if (!v) { setKeyStatus("Enter a key first.", true); return; }
  localStorage.setItem("gemini_key", v);
  state.apiKey = v;
  setKeyStatus("Saved ✓");
});
function setKeyStatus(msg, err = false) {
  const el = $("keyStatus");
  el.textContent = msg;
  el.classList.toggle("err", err);
}

/* ---------------- Mode ---------------- */
document.querySelectorAll("#modeSeg button").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll("#modeSeg button").forEach(b => b.classList.remove("on"));
    btn.classList.add("on");
    state.mode = btn.dataset.mode;
    $("customWrap").classList.toggle("hidden", state.mode !== "generic");
  });
});

/* ---------------- File pick ---------------- */
$("pickBtn").addEventListener("click", () => $("fileInput").click());
$("fileInput").addEventListener("change", async (e) => {
  const f = e.target.files && e.target.files[0];
  if (!f) return;
  await loadImage(f);
});

async function loadImage(file) {
  const maxDim = parseInt($("maxDim").value, 10);
  const { blob, dataUrl } = await resizeImage(file, maxDim);
  state.imageBlob = blob;
  state.imageDataUrl = dataUrl;

  const img = $("preview");
  img.onload = () => {
    resetView();
    sizeOverlay();
  };
  img.src = dataUrl;

  $("viewer").classList.remove("hidden");
  $("countBadge").classList.add("hidden");
  $("countBtn").disabled = false;
  state.detections = [];
  drawOverlay();
  setStatus("");
}

function resizeImage(file, maxEdge) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        let { width, height } = img;
        const scale = Math.min(1, maxEdge / Math.max(width, height));
        width = Math.round(width * scale);
        height = Math.round(height * scale);
        const c = document.createElement("canvas");
        c.width = width; c.height = height;
        const ctx = c.getContext("2d");
        ctx.drawImage(img, 0, 0, width, height);
        c.toBlob(blob => {
          const url = c.toDataURL("image/jpeg", 0.9);
          resolve({ blob, dataUrl: url, width, height });
        }, "image/jpeg", 0.9);
      };
      img.onerror = reject;
      img.src = reader.result;
    };
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

/* ---------------- Overlay drawing ---------------- */
function sizeOverlay() {
  const img = $("preview");
  const canvas = $("overlay");
  // match canvas pixel size to the displayed image's natural size
  canvas.width = img.naturalWidth;
  canvas.height = img.naturalHeight;
  // But CSS size matches the img (100%/100%)
  drawOverlay();
}

function drawOverlay() {
  const canvas = $("overlay");
  const ctx = canvas.getContext("2d");
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  if (!state.detections.length) return;

  const w = canvas.width, h = canvas.height;
  // scale marker size with image & zoom
  const base = Math.max(w, h) / 140;
  const markerR = Math.max(5, base / Math.max(1, state.zoom * 0.8));
  const fontSize = Math.max(9, base * 0.85 / Math.max(1, state.zoom * 0.6));

  ctx.lineWidth = Math.max(1, markerR * 0.18);
  ctx.font = `600 ${fontSize}px system-ui, sans-serif`;
  ctx.textAlign = "center";
  ctx.textBaseline = "middle";

  state.detections.forEach((p, i) => {
    const x = p.x * w, y = p.y * h;
    ctx.beginPath();
    ctx.arc(x, y, markerR, 0, Math.PI * 2);
    ctx.fillStyle = "rgba(124, 212, 176, 0.28)";
    ctx.fill();
    ctx.strokeStyle = "rgba(124, 212, 176, 0.95)";
    ctx.stroke();

    const label = String(i + 1);
    ctx.fillStyle = "#0b1a14";
    // white halo for readability
    ctx.strokeStyle = "rgba(255,255,255,0.9)";
    ctx.lineWidth = Math.max(2, fontSize * 0.25);
    ctx.strokeText(label, x, y);
    ctx.fillText(label, x, y);
    ctx.lineWidth = Math.max(1, markerR * 0.18);
  });
}

/* ---------------- Pan & Zoom ---------------- */
const viewer = $("viewer");
const stage = $("stage");
function applyTransform() {
  stage.style.transform = `translate(${state.panX}px, ${state.panY}px) scale(${state.zoom})`;
  drawOverlay();
}
function resetView() { state.zoom = 1; state.panX = 0; state.panY = 0; applyTransform(); }
$("zoomIn").addEventListener("click", () => { state.zoom = Math.min(8, state.zoom * 1.35); applyTransform(); });
$("zoomOut").addEventListener("click", () => { state.zoom = Math.max(1, state.zoom / 1.35); if (state.zoom === 1) { state.panX = 0; state.panY = 0; } applyTransform(); });
$("zoomReset").addEventListener("click", resetView);

let dragStart = null;
viewer.addEventListener("pointerdown", (e) => {
  if (state.zoom <= 1) return;
  viewer.setPointerCapture(e.pointerId);
  dragStart = { x: e.clientX - state.panX, y: e.clientY - state.panY };
});
viewer.addEventListener("pointermove", (e) => {
  if (!dragStart) return;
  state.panX = e.clientX - dragStart.x;
  state.panY = e.clientY - dragStart.y;
  clampPan();
  applyTransform();
});
viewer.addEventListener("pointerup", () => dragStart = null);
viewer.addEventListener("pointercancel", () => dragStart = null);

function clampPan() {
  const rect = viewer.getBoundingClientRect();
  const maxX = (state.zoom - 1) * rect.width;
  const maxY = (state.zoom - 1) * rect.height;
  state.panX = Math.min(0, Math.max(-maxX, state.panX));
  state.panY = Math.min(0, Math.max(-maxY, state.panY));
}

// pinch zoom
let pinch = null;
viewer.addEventListener("touchstart", (e) => {
  if (e.touches.length === 2) {
    e.preventDefault();
    pinch = {
      d: touchDist(e.touches),
      zoom: state.zoom
    };
  }
}, { passive: false });
viewer.addEventListener("touchmove", (e) => {
  if (e.touches.length === 2 && pinch) {
    e.preventDefault();
    const d = touchDist(e.touches);
    state.zoom = Math.max(1, Math.min(8, pinch.zoom * (d / pinch.d)));
    if (state.zoom === 1) { state.panX = 0; state.panY = 0; }
    clampPan();
    applyTransform();
  }
}, { passive: false });
viewer.addEventListener("touchend", () => pinch = null);
function touchDist(t) {
  const dx = t[0].clientX - t[1].clientX;
  const dy = t[0].clientY - t[1].clientY;
  return Math.hypot(dx, dy);
}

/* ---------------- Count via Gemini ---------------- */
$("countBtn").addEventListener("click", runCount);

function buildPrompt() {
  const density = $("density").value;
  let subject;
  if (state.mode === "beadlinks") {
    subject =
      "tiny wire-wrapped bead links. Each individual link is ONE unit. A link looks like: a small bead (pearl, gem, or colored stone) with a gold or silver wire loop on each end (sometimes one end). They often overlap and clump. Count each SINGLE bead-on-wire piece exactly once, even when tangled together. Do NOT count the two end-loops as separate items — loops + bead = 1 piece.";
  } else if (state.mode === "stones") {
    subject = "individual stones or beads sitting in the container. Count each distinct stone, even if they touch or overlap. Ignore reflections, shadows, and background texture.";
  } else {
    const custom = $("customObj").value.trim() || "items of interest";
    subject = custom + ". Count each distinct item exactly once.";
  }

  const densityHint = {
    sparse: "Items are spread out with clear spacing.",
    normal: "Items have moderate spacing with some clusters.",
    dense: "Items are tightly packed and heavily overlapping — look carefully at each cluster and segment them."
  }[density];

  return `You are a precise visual counting system. Detect every ${subject}

${densityHint}

Return ONLY a JSON array (no prose, no markdown, no code fence) of objects with normalized coordinates:
[{"x": 0.523, "y": 0.411}, ...]

- x and y are the CENTER of each item, as fractions of image width and height (0.0 to 1.0).
- Include EVERY item, even small or partially occluded ones. Err on the side of counting clustered items individually rather than merging them.
- Do not include a count field, explanations, or any other keys. Just the array.`;
}

async function runCount() {
  if (!state.apiKey) { setStatus("Add your API key above first.", true); return; }
  if (!state.imageBlob) { setStatus("Pick a photo first.", true); return; }

  $("countBtn").disabled = true;
  setStatus("Analyzing…", false, true);

  try {
    const base64 = await blobToBase64(state.imageBlob);
    const prompt = buildPrompt();

    const body = {
      contents: [{
        parts: [
          { text: prompt },
          { inline_data: { mime_type: "image/jpeg", data: base64 } }
        ]
      }],
      generationConfig: {
        temperature: 0.1,
        topP: 0.9,
        maxOutputTokens: 8192,
        responseMimeType: "application/json"
      }
    };

    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${encodeURIComponent(state.apiKey)}`;
    const res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body)
    });

    if (!res.ok) {
      const errTxt = await res.text();
      throw new Error(`API ${res.status}: ${errTxt.slice(0, 200)}`);
    }

    const data = await res.json();
    const text = data?.candidates?.[0]?.content?.parts?.[0]?.text || "";
    const points = parsePoints(text);

    if (!points.length) {
      setStatus("No items detected. Try a clearer photo or switch density to 'dense'.", true);
      state.detections = [];
      drawOverlay();
      $("countBadge").classList.add("hidden");
      return;
    }

    state.detections = points;
    drawOverlay();
    $("countBadge").textContent = `${points.length} item${points.length === 1 ? "" : "s"}`;
    $("countBadge").classList.remove("hidden");
    setStatus(`Counted ${points.length}. Pinch to zoom in and verify.`);

  } catch (err) {
    console.error(err);
    setStatus(err.message || "Something went wrong.", true);
  } finally {
    $("countBtn").disabled = false;
  }
}

function parsePoints(text) {
  if (!text) return [];
  let t = text.trim();
  // strip code fences just in case
  t = t.replace(/^```json\s*/i, "").replace(/^```\s*/i, "").replace(/\s*```$/i, "");
  // find first [ and last ]
  const i = t.indexOf("["), j = t.lastIndexOf("]");
  if (i === -1 || j === -1) return [];
  try {
    const arr = JSON.parse(t.slice(i, j + 1));
    if (!Array.isArray(arr)) return [];
    return arr
      .map(p => {
        // accept {x,y} or {point:[y,x]} or [x,y]
        if (Array.isArray(p) && p.length >= 2) return { x: +p[0], y: +p[1] };
        if (p && typeof p === "object") {
          if ("x" in p && "y" in p) return { x: +p.x, y: +p.y };
          if (Array.isArray(p.point) && p.point.length >= 2) {
            // some Gemini prompts return [y,x] in 0..1000 — try to normalize
            let [a, b] = p.point;
            if (a > 1 || b > 1) { a /= 1000; b /= 1000; }
            return { x: +b, y: +a };
          }
        }
        return null;
      })
      .filter(p => p && Number.isFinite(p.x) && Number.isFinite(p.y) && p.x >= 0 && p.x <= 1 && p.y >= 0 && p.y <= 1);
  } catch (e) {
    console.warn("parse failed", e, t);
    return [];
  }
}

function blobToBase64(blob) {
  return new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onload = () => {


