<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Charm Counter</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap');
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0d0b08; --surface: #1a1710; --border: #2e2a18;
    --accent: #e8c96d; --green: #5de08a; --red: #c4523a;
    --text: #f0ebe3; --muted: #7a6f55; --radius: 14px;
  }
  body { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; min-height: 100dvh; display: flex; flex-direction: column; }
  header { padding: 16px 20px 12px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); position: sticky; top: 0; background: var(--bg); z-index: 100; }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-icon { width: 34px; height: 34px; background: var(--accent); border-radius: 8px; display: grid; place-items: center; font-size: 18px; }
  h1 { font-size: 1.1rem; font-weight: 800; letter-spacing: -0.02em; }
  .count-badge { font-family: 'Space Mono', monospace; font-size: 1.4rem; font-weight: 700; color: var(--accent); background: rgba(232,201,109,0.12); border: 1.5px solid rgba(232,201,109,0.3); border-radius: 10px; padding: 4px 14px; min-width: 60px; text-align: center; transition: transform 0.15s; }
  .count-badge.bump { transform: scale(1.25); }
  main { flex: 1; display: flex; flex-direction: column; padding: 14px; gap: 12px; padding-bottom: 30px; }

  .status-bar { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 10px 14px; font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--muted); display: flex; align-items: center; gap: 8px; }
  .status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .status-bar.loading .status-dot { animation: pulse 1s infinite; }
  .status-bar.ready .status-dot { background: var(--green); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.2} }

  .upload-zone { background: var(--surface); border: 2px dashed var(--border); border-radius: var(--radius); padding: 28px 20px; display: flex; flex-direction: column; align-items: center; gap: 14px; text-align: center; }
  .upload-icon { font-size: 2.6rem; }
  .upload-zone h2 { font-size: 1rem; font-weight: 700; }
  .upload-zone p { font-size: 0.73rem; color: var(--muted); font-family: 'Space Mono', monospace; line-height: 1.5; }
  .upload-buttons { display: flex; gap: 10px; width: 100%; }
  .upload-btn { flex: 1; background: var(--accent); color: #0d0b08; border: none; border-radius: 10px; padding: 13px 10px; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.85rem; cursor: pointer; transition: all 0.15s; }
  .upload-btn:active { filter: brightness(0.85); transform: scale(0.97); }
  .upload-btn.secondary { background: var(--surface); color: var(--text); border: 1.5px solid var(--border); }
  #file-camera, #file-gallery { display: none; }

  .canvas-section { display: none; flex-direction: column; gap: 10px; }
  .canvas-section.active { display: flex; }
  .canvas-wrapper { position: relative; border-radius: var(--radius); overflow: hidden; border: 1.5px solid var(--border); background: #000; }
  #display-canvas { display: block; width: 100%; height: auto; max-height: 50dvh; }
  #src-canvas { display: none; }

  .controls-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; display: flex; flex-direction: column; gap: 11px; }
  .controls-title { font-size: 0.72rem; font-weight: 700; color: var(--muted); font-family: 'Space Mono', monospace; }
  .hint { font-size: 0.68rem; color: var(--muted); font-family: 'Space Mono', monospace; line-height: 1.55; }

  /* Gold range visual */
  .gold-range-bar { height: 8px; border-radius: 4px; background: linear-gradient(to right, hsl(15,80%,50%), hsl(35,90%,55%)); border: 1px solid var(--border); }

  .slider-row { display: flex; align-items: center; gap: 8px; }
  .slider-label { font-size: 0.7rem; color: var(--muted); font-family: 'Space Mono', monospace; min-width: 100px; }
  input[type=range] { flex: 1; accent-color: var(--accent); cursor: pointer; }
  .slider-val { font-family: 'Space Mono', monospace; font-size: 0.7rem; color: var(--accent); min-width: 32px; text-align: right; }

  .sep { height: 1px; background: var(--border); }

  .tab-row { display: flex; gap: 6px; }
  .tab-btn { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.72rem; padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border); cursor: pointer; background: transparent; color: var(--muted); transition: all 0.15s; }
  .tab-btn.active { background: var(--accent); color: #0d0b08; border-color: var(--accent); }
  .tab-panel { display: none; flex-direction: column; gap: 10px; }
  .tab-panel.active { display: flex; }

  .result-info { background: rgba(232,201,109,0.07); border: 1px solid rgba(232,201,109,0.2); border-radius: 10px; padding: 10px 14px; font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--muted); display: none; line-height: 1.65; }
  .result-info.show { display: block; }
  .result-info strong { color: var(--accent); }

  .toolbar { display: flex; gap: 8px; }
  .btn { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.82rem; padding: 11px 16px; border-radius: 10px; border: 1.5px solid transparent; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .btn-gold { background: var(--accent); color: #0d0b08; border-color: var(--accent); flex: 1; }
  .btn-gold:active { filter: brightness(0.85); transform: scale(0.97); }
  .btn-gold:disabled { opacity: 0.4; pointer-events: none; }
  .btn-green { background: var(--green); color: #0d0b08; border-color: var(--green); }
  .btn-green:active { filter: brightness(0.85); transform: scale(0.97); }
  .btn-ghost { background: var(--surface); color: var(--muted); border-color: var(--border); }
  .btn-ghost:active { background: var(--border); transform: scale(0.97); }

  /* Manual add/remove tap mode */
  .mode-bar { display: flex; gap: 8px; align-items: center; }
  .mode-label { font-size: 0.7rem; color: var(--muted); font-family: 'Space Mono', monospace; }
  .mode-btn { font-family: 'Space Mono', monospace; font-size: 0.7rem; padding: 5px 10px; border-radius: 7px; border: 1px solid var(--border); cursor: pointer; background: var(--bg); color: var(--muted); transition: all 0.15s; }
  .mode-btn.active-add { background: var(--green); color: #0d0b08; border-color: var(--green); }
  .mode-btn.active-remove { background: var(--red); color: #fff; border-color: var(--red); }

  .history-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .history-header { padding: 10px 16px; font-size: 0.72rem; font-family: 'Space Mono', monospace; color: var(--muted); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; }
  .history-list { max-height: 150px; overflow-y: auto; }
  .history-item { display: flex; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); gap: 10px; }
  .history-item:last-child { border-bottom: none; }
  .history-item .thumb { width: 36px; height: 36px; border-radius: 6px; object-fit: cover; border: 1px solid var(--border); flex-shrink: 0; }
  .h-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.8rem; }
  .h-count { font-family: 'Space Mono', monospace; color: var(--accent); font-weight: 700; }
  .empty-history { padding: 20px; text-align: center; color: var(--muted); font-size: 0.75rem; font-family: 'Space Mono', monospace; }

  .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 10px 20px; border-radius: 40px; font-size: 0.78rem; font-family: 'Space Mono', monospace; z-index: 999; transition: transform 0.25s cubic-bezier(.34,1.56,.64,1); pointer-events: none; white-space: nowrap; max-width: 90vw; text-align: center; }
  .toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">🪬</div>
    <h1>Charm Counter</h1>
  </div>
  <div class="count-badge" id="count-badge">0</div>
</header>

<main>
  <div class="status-bar loading" id="status-bar">
    <div class="status-dot"></div>
    <span id="status-text">Loading OpenCV… (first load ~10 sec, then offline forever)</span>
  </div>

  <div class="upload-zone" id="upload-zone">
    <div class="upload-icon">🪬</div>
    <h2>Add photo of charms</h2>
    <p>Detects gold wire — works for any colour gem or pearl<br>100% offline after first load</p>
    <div class="upload-buttons">
      <button class="upload-btn" id="btn-camera">📷 Camera</button>
      <button class="upload-btn secondary" id="btn-gallery">🖼 Gallery</button>
    </div>
  </div>

  <input type="file" id="file-camera" accept="image/*" capture="environment">
  <input type="file" id="file-gallery" accept="image/*">
  <canvas id="src-canvas"></canvas>

  <div class="canvas-section" id="canvas-section">
    <div class="canvas-wrapper">
      <canvas id="display-canvas"></canvas>
    </div>

    <!-- Manual correction mode -->
    <div class="mode-bar">
      <span class="mode-label">Manual fix:</span>
      <button class="mode-btn" id="mode-off-btn">Off</button>
      <button class="mode-btn" id="mode-add-btn">+ Add tap</button>
      <button class="mode-btn" id="mode-remove-btn">− Remove tap</button>
      <button class="mode-btn" id="undo-btn">↩ Undo</button>
    </div>

    <div class="controls-card">
      <div class="controls-title">⚙ GOLD WIRE DETECTION</div>

      <div class="tab-row">
        <button class="tab-btn active" id="tab-gold-btn">🟡 Gold tune</button>
        <button class="tab-btn" id="tab-size-btn">📐 Size</button>
        <button class="tab-btn" id="tab-display-btn">🔵 Display</button>
      </div>

      <!-- GOLD TUNE TAB -->
      <div class="tab-panel active" id="tab-gold">
        <div class="hint">These are pre-set for gold/yellow wire. Only change if your wire looks different.</div>
        <div class="gold-range-bar"></div>
        <div class="slider-row">
          <span class="slider-label">Hue min (yellow)</span>
          <input type="range" id="sl-hmin" min="0" max="60" value="15">
          <span class="slider-val" id="vl-hmin">15</span>
        </div>
        <div class="slider-row">
          <span class="slider-label">Hue max (gold)</span>
          <input type="range" id="sl-hmax" min="10" max="90" value="38">
          <span class="slider-val" id="vl-hmax">38</span>
        </div>
        <div class="slider-row">
          <span class="slider-label">Min saturation</span>
          <input type="range" id="sl-sat" min="20" max="255" value="70">
          <span class="slider-val" id="vl-sat">70</span>
        </div>
        <div class="slider-row">
          <span class="slider-label">Min brightness</span>
          <input type="range" id="sl-bri" min="20" max="255" value="90">
          <span class="slider-val" id="vl-bri">90</span>
        </div>
      </div>

      <!-- SIZE TAB -->
      <div class="tab-panel" id="tab-size">
        <div class="hint">
          <b>Min/Max blob</b>: size of each gold piece detected.<br>
          <b>Group distance</b>: gold blobs closer than this = 1 charm. Increase if one charm is counting as many. Decrease if separate charms are merging.
        </div>
        <div class="slider-row">
          <span class="slider-label">Min blob (px)</span>
          <input type="range" id="sl-min" min="1" max="40" value="3">
          <span class="slider-val" id="vl-min">3</span>
        </div>
        <div class="slider-row">
          <span class="slider-label">Max blob (px)</span>
          <input type="range" id="sl-max" min="10" max="400" value="150">
          <span class="slider-val" id="vl-max">150</span>
        </div>
        <div class="slider-row">
          <span class="slider-label">Group distance</span>
          <input type="range" id="sl-group" min="5" max="120" value="40">
          <span class="slider-val" id="vl-group">40</span>
        </div>
      </div>

      <!-- DISPLAY TAB -->
      <div class="tab-panel" id="tab-display">
        <div class="slider-row">
          <span class="slider-label">Dot size</span>
          <input type="range" id="sl-dot" min="4" max="30" value="12">
          <span class="slider-val" id="vl-dot">12</span>
        </div>
        <div class="slider-row">
          <span class="slider-label">Show numbers</span>
          <input type="range" id="sl-nums" min="0" max="1" value="1" step="1">
          <span class="slider-val" id="vl-nums">Yes</span>
        </div>
      </div>
    </div>

    <div class="result-info" id="result-info"></div>

    <div class="toolbar">
      <button class="btn btn-gold" id="detect-btn" disabled>🔍 Count Charms</button>
      <button class="btn btn-green" id="save-btn">💾 Save</button>
      <button class="btn btn-ghost" id="new-btn">＋</button>
    </div>
  </div>

  <div class="history-section">
    <div class="history-header">
      <span>SAVED COUNTS</span>
      <span id="total-saved">0 saved</span>
    </div>
    <div class="history-list" id="history-list">
      <div class="empty-history">No saved counts yet</div>
    </div>
  </div>
</main>
<div class="toast" id="toast"></div>

<script async src="https://docs.opencv.org/4.9.0/opencv.js" onload="onOpenCvReady()" onerror="onOpenCvError()"></script>
<script>
  let cvReady = false, img = null, imgName = 'photo';
  let charms = [];       // final grouped charm positions [{x,y}]
  let tapMode = 'off';   // 'off' | 'add' | 'remove'
  let savedHistory = JSON.parse(localStorage.getItem('charm_history') || '[]');

  const el = id => document.getElementById(id);
  const statusBar    = el('status-bar'), statusText = el('status-text');
  const uploadZone   = el('upload-zone'), canvasSection = el('canvas-section');
  const displayCanvas= el('display-canvas'), srcCanvas = el('src-canvas');
  const countBadge   = el('count-badge'), detectBtn = el('detect-btn');
  const saveBtn      = el('save-btn'), newBtn = el('new-btn');
  const historyList  = el('history-list'), totalSaved = el('total-saved');
  const toast        = el('toast'), resultInfo = el('result-info');
  const dctx         = displayCanvas.getContext('2d');

  function onOpenCvReady() {
    cvReady = true;
    statusBar.className = 'status-bar ready';
    statusText.textContent = 'OpenCV ready ✓ — fully offline now';
    if (img) detectBtn.disabled = false;
  }
  function onOpenCvError() {
    statusText.textContent = '⚠ OpenCV failed to load — need internet for first load.';
  }

  // ── TABS ──
  ['gold','size','display'].forEach(name => {
    el('tab-' + name + '-btn').addEventListener('click', () => {
      ['gold','size','display'].forEach(t => {
        el('tab-' + t).classList.toggle('active', t === name);
        el('tab-' + t + '-btn').classList.toggle('active', t === name);
      });
    });
  });

  // ── SLIDERS ──
  [['sl-hmin','vl-hmin'],['sl-hmax','vl-hmax'],['sl-sat','vl-sat'],['sl-bri','vl-bri'],
   ['sl-min','vl-min'],['sl-max','vl-max'],['sl-group','vl-group'],['sl-dot','vl-dot']
  ].forEach(([s,v]) => el(s).addEventListener('input', () => { el(v).textContent = el(s).value; }));
  el('sl-nums').addEventListener('input', function() {
    el('vl-nums').textContent = this.value === '1' ? 'Yes' : 'No';
    if (charms.length) redrawDots();
  });
  el('sl-dot').addEventListener('input', () => { if (charms.length) redrawDots(); });

  // ── UPLOAD ──
  el('btn-camera').addEventListener('click',  () => { el('file-camera').value=''; el('file-camera').click(); });
  el('btn-gallery').addEventListener('click', () => { el('file-gallery').value=''; el('file-gallery').click(); });

  function handleFile(file) {
    if (!file) return;
    imgName = file.name || 'photo';
    const reader = new FileReader();
    reader.onload = ev => {
      const image = new Image();
      image.onload = () => {
        const MAX = 1400;
        let w = image.naturalWidth, h = image.naturalHeight;
        if (w > MAX) { h = Math.round(h * MAX / w); w = MAX; }
        srcCanvas.width = w; srcCanvas.height = h;
        srcCanvas.getContext('2d').drawImage(image, 0, 0, w, h);
        displayCanvas.width = w; displayCanvas.height = h;
        dctx.drawImage(image, 0, 0, w, h);
        img = image; charms = [];
        uploadZone.style.display = 'none';
        canvasSection.classList.add('active');
        resultInfo.classList.remove('show');
        setTapMode('off');
        if (cvReady) detectBtn.disabled = false;
        updateCount();
      };
      image.src = ev.target.result;
    };
    reader.readAsDataURL(file);
  }
  el('file-camera').addEventListener('change', e => handleFile(e.target.files[0]));
  el('file-gallery').addEventListener('change', e => handleFile(e.target.files[0]));

  // ── MANUAL TAP MODE ──
  function setTapMode(mode) {
    tapMode = mode;
    el('mode-off-btn').className    = 'mode-btn' + (mode === 'off'    ? ' active-add' : '');
    el('mode-add-btn').className    = 'mode-btn' + (mode === 'add'    ? ' active-add' : '');
    el('mode-remove-btn').className = 'mode-btn' + (mode === 'remove' ? ' active-remove' : '');
    displayCanvas.style.cursor = mode === 'off' ? 'default' : (mode === 'add' ? 'crosshair' : 'not-allowed');
  }
  el('mode-off-btn').addEventListener('click',    () => setTapMode('off'));
  el('mode-add-btn').addEventListener('click',    () => setTapMode('add'));
  el('mode-remove-btn').addEventListener('click', () => setTapMode('remove'));
  el('undo-btn').addEventListener('click', () => {
    if (!charms.length) return;
    charms.pop(); updateCount(); redrawDots(); showToast('Removed last dot');
  });

  function getCanvasPos(e) {
    const rect = displayCanvas.getBoundingClientRect();
    const src  = e.touches ? e.touches[0] : e;
    const scaleX = displayCanvas.width  / rect.width;
    const scaleY = displayCanvas.height / rect.height;
    return { x: (src.clientX - rect.left) * scaleX, y: (src.clientY - rect.top) * scaleY };
  }

  displayCanvas.addEventListener('touchstart', handleCanvasTap, { passive: false });
  displayCanvas.addEventListener('mousedown',  handleCanvasTap);

  function handleCanvasTap(e) {
    if (tapMode === 'off') return;
    e.preventDefault();
    const pos = getCanvasPos(e);
    const DOT = parseInt(el('sl-dot').value);

    if (tapMode === 'add') {
      charms.push({ x: pos.x, y: pos.y });
      updateCount(); redrawDots(); bumpBadge();
    } else if (tapMode === 'remove') {
      // Remove closest dot within tap radius
      let closest = -1, minDist = DOT * 3;
      charms.forEach((c, i) => {
        const d = Math.hypot(c.x - pos.x, c.y - pos.y);
        if (d < minDist) { minDist = d; closest = i; }
      });
      if (closest >= 0) {
        charms.splice(closest, 1);
        updateCount(); redrawDots();
        showToast('Dot removed');
      }
    }
  }

  // ── DETECT ──
  detectBtn.addEventListener('click', () => {
    if (!cvReady || !img) return;
    detectBtn.disabled = true;
    detectBtn.textContent = '⏳ Counting…';
    setTapMode('off');
    setTimeout(() => {
      try { runDetection(); } catch(e) { showToast('Error: ' + e.message); console.error(e); }
      detectBtn.disabled = false;
      detectBtn.textContent = '🔍 Count Charms';
    }, 50);
  });

  function runDetection() {
    const hMin = parseInt(el('sl-hmin').value), hMax = parseInt(el('sl-hmax').value);
    const sMin = parseInt(el('sl-sat').value),  vMin = parseInt(el('sl-bri').value);
    const minR = pa
